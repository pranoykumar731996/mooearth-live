    "test:production-readiness": "npm run test:mock-scan && npm run test:data-integrity"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "next": "16.2.9",
    "react": "19.2.4",
