{
  "name": "mooearth-live",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/update-sw-timestamp.js && next build",
    "start": "next start",
    "lint": "eslint",
    "generate-questions": "npx tsx scripts/generateQuestions.ts",
    "generate-country-questions": "npx tsx scripts/generateCountryQuestions.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
