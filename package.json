    "react-globe.gl": "^2.38.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jimp": "^1.6.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
